import io

fn main() {
    var gt = 10 > 5
    var eq = 5 == 5

    on (gt) {
        io.print("Control flow via Bool: OK")
    } off {
        io.print("Control flow via Bool: FAIL")
    }

    loop i in 0..10 per 2 on (i > 3) {
        io.print("i: " + i)
    } off {
        io.print("filtered")
    }

    var nums = list num { 1, 2, 3 }
    nums push 4
    io.print(nums at 0)

    var scores = map str num { "Ada" 100, "Kiro" 95 }
    io.print(scores at "Ada")

    check eq, "equality should hold"
}

main()
