import io

fn do_nothing() {
    io.print("Doing nothing")
}

fn signal() -> void {
    return
}

fn main() -> num {
    var ptr = adr str // Expected: None

    // Check if we can assign later
    ptr = ref "Now I exist"

    io.print(deref ptr)

    do_nothing()
    signal()

    var v_ptr = adr void
    io.print(v_ptr)

    return 0
}

io.print(main())
