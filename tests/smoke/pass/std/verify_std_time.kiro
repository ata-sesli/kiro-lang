import io

// Test for std time module
import std_time

fn main() {
    io.print("=== Testing std_time ===")

    // Test now
    io.print("Testing now...")
    var timestamp = std_time.now()
    io.print(timestamp)

    // Test monotonic
    io.print("Testing monotonic...")
    var mono = std_time.monotonic()
    io.print(mono)

    // Test sleep
    io.print("Testing sleep (100ms)...")
    var before = std_time.now()
    std_time.sleep(100)
    var after = std_time.now()
    var elapsed = after - before
    io.print(elapsed)

    io.print("=== std_time tests complete ===")
}

main()
