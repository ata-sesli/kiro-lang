import io

// Test for std env module
import std_env

fn main() {
    io.print("=== Testing std_env ===")

    // Test set
    io.print("Testing set...")
    std_env.set("KIRO_TEST_VAR", "hello_kiro")
    io.print("set: KIRO_TEST_VAR = hello_kiro")

    // Test get
    io.print("Testing get...")
    var get_result = std_env.get("KIRO_TEST_VAR")
    on (get_result) {
        io.print("get: " + get_result)
    } error {
        io.print("get: Error")
    }

    // Test get non-existent
    io.print("Testing get non-existent...")
    var missing = std_env.get("KIRO_NONEXISTENT_VAR_12345")
    on (missing) {
        io.print("unexpected: found " + missing)
    } error {
        io.print("get non-existent: Error (expected)")
    }

    // Test args
    io.print("Testing args...")
    var args_list = std_env.args()
    io.print("args: received argument list")

    io.print("=== std_env tests complete ===")
}

main()
