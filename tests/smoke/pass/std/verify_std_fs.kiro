import io

// Test for std fs module
import std_fs

fn main() {
    io.print("=== Testing std_fs ===")

    // Test write
    io.print("Testing write...")
    var write_result = std_fs.write("test_file.txt", "Hello from Kiro!")
    on (write_result) {
        io.print("write: Success")
    } error {
        io.print("write: Error")
    }

    // Test exists
    io.print("Testing exists...")
    var exists_result = std_fs.exists("test_file.txt")
    io.print(exists_result)

    // Test read
    io.print("Testing read...")
    var read_result = std_fs.read("test_file.txt")
    on (read_result) {
        io.print(read_result)
    } error {
        io.print("read: Error")
    }

    // Test remove
    io.print("Testing remove...")
    var remove_result = std_fs.remove("test_file.txt")
    on (remove_result) {
        io.print("remove: Success")
    } error {
        io.print("remove: Error")
    }

    // Verify file is gone
    io.print("Testing exists after remove...")
    var exists_after = std_fs.exists("test_file.txt")
    io.print(exists_after)

    io.print("=== std_fs tests complete ===")
}

main()
