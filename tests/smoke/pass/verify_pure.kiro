import io

pure fn add_pure(a: num, b: num) -> num {
    return a + b
}

pure fn check_scope(val: num) -> num {
    // Valid: Assign to LOCAL variable
    var local = 0
    local = val
    return local
}

fn main() {
    io.print("--- Pure Verification ---")

    // 1. Immutable Declaration
    x = 10
    io.print(x)

    // 2. Mutable Declaration
    var y = 20
    y = 21 // Mutation allowed
    io.print(y)

    // 3. Pure Call with Immutable (x)
    io.print(add_pure(x, 15))

    // 4. Pure Call with Literal (Immutable)
    io.print(add_pure(100, 200))

    // 5. Pure Scope check
    io.print(check_scope(5))

    io.print("--- Passed ---")
}

main()
