import io

fn main() {
    io.print("--- Type Compatibility Verification ---")

    // 1. Comparisons should return Bool (not float)
    var gt = 10 > 5
    var lt = 5 < 10
    var eq = 5 == 5
    var neq = 5 != 10

    io.print("Gt: " + gt)
    io.print("Lt: " + lt)
    io.print("Eq: " + eq)
    io.print("Neq: " + neq)

    // 2. Control flow should work with these bools
    on (gt) {
        io.print("Control flow via Bool: OK")
    } off {
        io.print("Control flow via Bool: FAIL")
    }

    // 3. Range support (newly added to Interpreter)
    io.print("Range Test:")
    loop i in 0..3 {
        io.print("i: " + i)
    }

    io.print("--- Verification Complete ---")
}
main()
