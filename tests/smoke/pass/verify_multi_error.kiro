import std_fs
import io


fn main() {
    io.print("Testing multi-error...")
    var res = std_fs.read("non_existent_file_xyz")

    // Test: Should skip PermissionDenied and match NotFound
    on (res) {
        io.print("Should not be here")
    } error PermissionDenied {
        io.print("Caught PermissionDenied (Unexpected)")
    } error NotFound {
        io.print("Caught NotFound (Expected)")
    } error {
        io.print("Caught generic (Unexpected)")
    }

    io.print("Done")
}
main()
