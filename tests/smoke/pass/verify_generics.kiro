import io

fn get_message() -> str {
    return "Hello Generics"
}

struct Container {
    ptr: adr str
    channel: pipe bool
}

fn entry() -> num {
    var p = ref "Current Status"
    var c = pipe bool

    io.print(deref p)
    give c true

    var res = take c
    on (res) {
        io.print("Pipe worked!")
    } off {
        io.print("Pipe failed")
    }

    io.print(get_message())
    return 0
}

io.print(entry())
