import io

error NotFound = "File not found"
error PermissionDenied = "Access denied"

fn maybe_fail(code: num) -> str! {
    on (code == 1) {
        return NotFound
    }
    on (code == 2) {
        return PermissionDenied
    }
    return "Success!"
}

fn process(code: num) -> str! {
    var result = maybe_fail(code)

    on (result) {
        io.print("Got: ")
        io.print(result)
        return result
    } error NotFound {
        io.print("NotFound caught, propagating...")
        return NotFound
    } error PermissionDenied {
        return PermissionDenied
    }
    return "unreachable"
}

fn main() {
    io.print("--- Error Handling Test ---")

    // Test 1: Success path
    io.print("Test 1: Success")
    // Since main is not failable, we must handle the result of maybe_fail
    var a = maybe_fail(0)
    on (a) {
        io.print(a)
    } error {
        io.print("Unexpected error")
    }

    // Test 2: Error creation and return
    io.print("Test 2: Error creation")
    var b = maybe_fail(1)
    on (b) {
        io.print("This should not print")
    } error NotFound {
        io.print("NotFound handled!")
    }

    // Test 3: Error propagation
    io.print("Test 3: Propagation")
    var c = process(1)
    on (c) {
        io.print(c)
    } error NotFound {
        io.print("NotFound propagated successfully!")
    }

    io.print("--- All Tests Passed ---")
}
main()
