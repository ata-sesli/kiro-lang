import io

// Test for std net module
import std_net

fn main() {
    io.print("=== Testing std_net ===")

    // Test get
    io.print("Testing get...")
    var get_result = std_net.get("https://httpbin.org/get")
    on (get_result) {
        io.print("get: received response")
    } error {
        io.print("get: Error")
    }

    // Test status
    io.print("Testing status...")
    var status_result = std_net.status("https://httpbin.org/status/200")
    on (status_result) {
        io.print(status_result)
    } error {
        io.print("status: Error")
    }

    // Test post
    io.print("Testing post...")
    var post_result = std_net.post("https://httpbin.org/post", "test body")
    on (post_result) {
        io.print("post: received response")
    } error {
        io.print("post: Error")
    }

    // Test body (passthrough)
    io.print("Testing body...")
    var body_result = std_net.body("test string")
    io.print(body_result)

    io.print("=== std_net tests complete ===")
}

main()
