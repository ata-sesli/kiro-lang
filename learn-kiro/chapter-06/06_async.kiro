import io

// Chapter 6: Async Execution

fn task(id: num) {
    // Simulate some work generally happens here
    io.print("Task " + id + " started.")
}

io.print("Starting tasks...")

// Spawn multiple tasks
loop i in 1..4 {
    run task(i)
}

io.print("All tasks spawned. Main exiting.")
// Note: In a real app, you'd likely wait for them or use pipes (Chapter 7).
