fn shout(msg: str) {
    print msg + "!!!"
}

pure fn multiply(a: num, b: num) -> num {
    return a * b
}

print "--- Functions ---"
shout("Kiro")

print "--- Pure Func ---"
print "3 * 4 = " + multiply(3, 4)

