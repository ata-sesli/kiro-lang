import io

// Chapter 8: Pointers

var val = 100
var p = ref val

// Reading
var v = deref p
io.print("Value via ptr: " + v)

// Writing
deref p = 200
var updated = deref p
io.print("Updated via p: " + updated)

// Opaque managed handle (adr void)
var any_ptr = adr void
any_ptr = p
io.print(any_ptr)

// Struct Pointers
struct Point { x: num y: num }
var pt = Point { x: 10, y: 20 }
var pt_ref = ref pt

// Auto-deref access
io.print("Point X: " + pt_ref.x)
